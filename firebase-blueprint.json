{
  "entities": {
    "Server": {
      "title": "Server",
      "description": "VLESS Server configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "protocol": { "type": "string" },
        "latency": { "type": "string" },
        "load": { "type": "number" },
        "expiryDate": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "config": { "type": "string" },
        "country": { "type": "string", "description": "2-letter country code" },
        "city": { "type": "string", "description": "City name" },
        "remark": { "type": "string", "description": "Optional remark for the subscription" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "protocol", "latency", "load", "expiryDate", "status", "config", "country", "city"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with admin privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    },
    "Warning": {
      "title": "Warning",
      "description": "Global warnings or maintenance messages",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error"] },
        "active": { "type": "boolean" },
        "replaceContent": { "type": "boolean", "description": "If true, hides the server list and shows only this message" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "type", "active", "replaceContent", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "subscriptionTitle": { "type": "string", "description": "Global title for VLESS subscription" }
      }
    }
  },
  "firestore": {
    "/servers/{serverId}": {
      "schema": "Server",
      "description": "Collection of VLESS servers managed by admin"
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global config"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of authorized admin UIDs"
    },
    "/warnings/{warningId}": {
      "schema": "Warning",
      "description": "System-wide alerts"
    }
  }
}
