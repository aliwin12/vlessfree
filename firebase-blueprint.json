{
  "entities": {
    "Server": {
      "title": "Server",
      "description": "VLESS Server configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "protocol": { "type": "string" },
        "latency": { "type": "string" },
        "load": { "type": "number" },
        "expiryDate": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "config": { "type": "string" },
        "country": { "type": "string", "description": "2-letter country code" },
        "city": { "type": "string", "description": "City name" },
        "isComingSoon": { "type": "boolean" },
        "isDisappearingSoon": { "type": "boolean" },
        "isSpecial": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "protocol", "latency", "load", "expiryDate", "status", "config", "country", "city"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with admin privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    },
    "Warning": {
      "title": "Warning",
      "description": "Global warnings or maintenance messages",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error"] },
        "active": { "type": "boolean" },
        "replaceContent": { "type": "boolean", "description": "If true, hides the server list and shows only this message" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "type", "active", "replaceContent", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "User report about a server issue",
      "type": "object",
      "properties": {
        "serverId": { "type": "string" },
        "serverName": { "type": "string" },
        "reason": { "type": "string", "enum": ["not_working", "info_error", "slow_speed", "other"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userIp": { "type": "string" },
        "browser": { "type": "string" },
        "country": { "type": "string" }
      },
      "required": ["serverId", "serverName", "reason", "status", "createdAt"]
    },
    "BlockedIP": {
      "title": "Blocked IP",
      "description": "IP addresses blocked from the system",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "reason": { "type": "string" },
        "blockedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ip", "blockedAt"]
    },
    "Visit": {
      "title": "Site Visit",
      "description": "Log of user visits",
      "type": "object",
      "properties": {
        "userIp": { "type": "string" },
        "browser": { "type": "string" },
        "country": { "type": "string" },
        "visitedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userIp", "visitedAt"]
    },
    "ServerSuggestion": {
      "title": "Server Suggestion",
      "description": "User suggested server for the platform",
      "type": "object",
      "properties": {
        "displayId": { "type": "string", "description": "6-digit unique identifier" },
        "name": { "type": "string" },
        "protocol": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "config": { "type": "string" },
        "expiryDate": { "type": "string", "description": "When the server expires" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userIp": { "type": "string" }
      },
      "required": ["displayId", "name", "protocol", "country", "city", "config", "expiryDate", "status", "createdAt"]
    },
    "ServerRemovalRequest": {
      "title": "Server Removal Request",
      "description": "User request to remove their suggested server",
      "type": "object",
      "properties": {
        "serverId": { "type": "string" },
        "suggestionId": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userIp": { "type": "string" }
      },
      "required": ["serverId", "suggestionId", "reason", "status", "createdAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "App generic settings document",
      "type": "object",
      "properties": {
        "value": { "type": "string" }
      },
      "required": ["value"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Public user profile configuration",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "telegram": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "displayName", "createdAt", "updatedAt"]
    },
    "UsernameClaim": {
      "title": "Username Claim",
      "description": "Mapping from username to uid to ensure uniqueness",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "createdAt"]
    }
  },
  "firestore": {
    "/servers/{serverId}": {
      "schema": "Server",
      "description": "Collection of VLESS servers managed by admin"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of authorized admin UIDs"
    },
    "/warnings/{warningId}": {
      "schema": "Warning",
      "description": "System-wide alerts"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "User submitted server issues"
    },
    "/blocked_ips/{ipId}": {
      "schema": "BlockedIP",
      "description": "IP blacklist"
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Visitor logs"
    },
    "/server_suggestions/{suggestionId}": {
      "schema": "ServerSuggestion",
      "description": "Queue for user suggested servers"
    },
    "/server_removals/{removalId}": {
      "schema": "ServerRemovalRequest",
      "description": "Requests for server removal"
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "General settings document"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Public user profiles"
    },
    "/usernames/{username}": {
      "schema": "UsernameClaim",
      "description": "Direct mapping of lowercase usernames to prevent duplicates"
    }
  }
}
