rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'bubinadubina5@gmail.com' ||
        request.auth.token.email == 'intelxeonuser@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Servers Collection
    function isValidServer(data) {
      return data.name is string &&
             data.protocol is string &&
             data.status is string &&
             data.config is string;
    }

    match /servers/{serverId} {
      allow get, list: if true;
      allow create: if (isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid)) && 
                      isValidServer(incoming());
      allow update: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // 2. Warnings Collection
    function isValidWarning(data) {
      return data.text is string && data.text.size() <= 1000 &&
             data.type in ['info', 'warning', 'error'] &&
             data.active is bool &&
             data.replaceContent is bool;
    }

    match /warnings/{warningId} {
      allow get, list: if true;
      allow create: if isAdmin() && 
                      isValidWarning(incoming()) && 
                      incoming().createdAt == request.time;
      allow update: if isAdmin() && 
                      isValidWarning(incoming());
      allow delete: if isAdmin();
    }

    // 3. Admin Roles Collection
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isVerified() && request.auth.token.email == 'bubinadubina5@gmail.com';
    }

    // 4. Reports Collection
    match /reports/{reportId} {
      allow create: if isValidId(incoming().serverId) && 
                       incoming().createdAt == request.time;
      allow get: if true; // Publicly get status if knowing the exact document ID
      allow list, update, delete: if isAdmin();
    }

    // 5. Visits Collection
    match /visits/{visitId} {
      allow create: if true; // Everyone can log a visit (client side)
      allow get, list, update, delete: if isAdmin();
    }

    // 6. Blocked IPs
    match /blocked_ips/{ipId} {
      allow read: if true; // Publicly readable so client can check if they are blocked
      allow write: if isAdmin();
    }

    // 7. Server Suggestions
    function isValidSuggestion(data) {
      return data.displayId is string && data.displayId.size() == 6 &&
             data.name is string && data.name.size() <= 64 &&
             data.protocol is string &&
             data.expiryDate is string &&
             data.country is string &&
             data.city is string &&
             data.config is string && data.config.size() <= 2000 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (data.get('category', null) == null || data.get('category', null) is string) &&
             (data.get('notes', null) == null || data.get('notes', null) is string) &&
             (data.get('customIcon', null) == null || data.get('customIcon', null) is string) &&
             (data.get('isPrivate', null) == null || data.get('isPrivate', null) is bool) &&
             (data.get('hideAuthor', null) == null || data.get('hideAuthor', null) is bool) &&
             (data.get('allowedClients', null) == null || data.get('allowedClients', null) is list) &&
             (data.get('speedLimit', null) == null || data.get('speedLimit', null) is string) &&
             (data.get('isPinned', null) == null || data.get('isPinned', null) is bool);
    }

    match /server_suggestions/{suggestionId} {
      allow create: if isValidSuggestion(incoming()) && 
                       (incoming().status == 'pending' || incoming().status == 'approved') &&
                       incoming().createdAt == request.time;
      allow get: if true; // Anyone knowing the suggestion ID can check its status/details
      allow list: if isAdmin() || 
                    (resource.data.status == 'approved') || 
                    (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // 8. Server Removals
    function isValidRemoval(data) {
      return data.serverId is string &&
             data.suggestionId is string &&
             data.reason is string &&
             data.status in ['pending', 'processed', 'rejected'];
    }

    match /server_removals/{removalId} {
      allow create: if isValidRemoval(incoming()) &&
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      allow get, list, update, delete: if isAdmin();
    }

    // 10. Settings Collection
    function isValidSetting(data) {
      return data.value is string && data.value.size() <= 1000;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSetting(incoming());
    }

    // 11. User Profiles & Username Claims
    function isValidUserProfile(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 15 &&
             data.username.matches('^[a-zA-Z0-9_]+$') &&
             data.displayName is string && data.displayName.size() <= 40 &&
             (data.get('bio', null) == null || (data.get('bio', null) is string && data.get('bio', null).size() <= 200)) &&
             (data.get('telegram', null) == null || (data.get('telegram', null) is string && data.get('telegram', null).size() <= 100)) &&
             (data.get('avatarUrl', null) == null || (data.get('avatarUrl', null) is string && data.get('avatarUrl', null).size() <= 500)) &&
             (data.get('followersCount', null) == null || data.get('followersCount', null) is int) &&
             (data.get('followingCount', null) == null || data.get('followingCount', null) is int) &&
             (data.get('statusText', null) == null || (data.get('statusText', null) is string && data.get('statusText', null).size() <= 100)) &&
             (data.get('profileColor', null) == null || (data.get('profileColor', null) is string && data.get('profileColor', null).size() <= 50)) &&
             (data.get('donationUrl', null) == null || (data.get('donationUrl', null) is string && data.get('donationUrl', null).size() <= 500)) &&
             (data.get('contactOther', null) == null || (data.get('contactOther', null) is string && data.get('contactOther', null).size() <= 200)) &&
             (data.get('showHistoryOnPublic', null) == null || data.get('showHistoryOnPublic', null) is bool);
    }

    function isValidFollower(data) {
      return data.followerUid is string && data.followerUid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 60 &&
             data.username is string && data.username.size() <= 30 &&
             (data.get('avatarUrl', null) == null || (data.get('avatarUrl', null) is string && data.get('avatarUrl', null).size() <= 500)) &&
             data.createdAt == request.time;
    }

    function isValidFollowing(data) {
      return data.followingUid is string && data.followingUid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 60 &&
             data.username is string && data.username.size() <= 30 &&
             (data.get('avatarUrl', null) == null || (data.get('avatarUrl', null) is string && data.get('avatarUrl', null).size() <= 500)) &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if true;
      allow create: if isSignedIn() && request.auth.uid == userId &&
                      isValidUserProfile(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time &&
                      getAfter(/databases/$(database)/documents/usernames/$(incoming().username)).data.uid == request.auth.uid;
      allow update: if (isSignedIn() && request.auth.uid == userId &&
                      isValidUserProfile(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      (incoming().username == existing().username ||
                       getAfter(/databases/$(database)/documents/usernames/$(incoming().username)).data.uid == request.auth.uid)) ||
                     (isSignedIn() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['followersCount']) &&
                      (
                        (!('followersCount' in existing()) && (incoming().followersCount == 1 || incoming().followersCount == -1)) ||
                        ('followersCount' in existing() && (incoming().followersCount == existing().followersCount + 1 || incoming().followersCount == existing().followersCount - 1))
                      )) ||
                     (isSignedIn() && request.auth.uid == userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['followingCount']) &&
                      (
                        (!('followingCount' in existing()) && (incoming().followingCount == 1 || incoming().followingCount == -1)) ||
                        ('followingCount' in existing() && (incoming().followingCount == existing().followingCount + 1 || incoming().followingCount == existing().followingCount - 1))
                      ));
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/followers/{followerId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == followerId &&
                      isValidFollower(incoming());
      allow delete: if isSignedIn() && request.auth.uid == followerId;
    }

    match /users/{userId}/following/{followingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId &&
                      isValidFollowing(incoming());
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() &&
                      incoming().uid == request.auth.uid &&
                      incoming().createdAt == request.time &&
                      username.size() >= 3 && username.size() <= 15 &&
                      username.matches('^[a-zA-Z0-9_]+$') &&
                      username == username.lower();
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    // 9. Test Path (Internal)
    match /test/connection {
      allow read: if true;
    }
  }
}
