rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'bubinadubina5@gmail.com' ||
        request.auth.token.email == 'intelxeonuser@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Servers Collection
    function isValidServer(data) {
      return data.name is string &&
             data.protocol is string &&
             data.status is string &&
             data.config is string;
    }

    match /servers/{serverId} {
      allow get, list: if true;
      allow create: if isAdmin() && 
                      isValidServer(incoming());
      allow update: if isAdmin() && 
                      isValidServer(incoming());
      allow delete: if isAdmin();
    }

    // 2. Warnings Collection
    function isValidWarning(data) {
      return data.text is string && data.text.size() <= 1000 &&
             data.type in ['info', 'warning', 'error'] &&
             data.active is bool &&
             data.replaceContent is bool;
    }

    match /warnings/{warningId} {
      allow get, list: if true;
      allow create: if isAdmin() && 
                      isValidWarning(incoming()) && 
                      incoming().createdAt == request.time;
      allow update: if isAdmin() && 
                      isValidWarning(incoming());
      allow delete: if isAdmin();
    }

    // 3. Admin Roles Collection
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isVerified() && request.auth.token.email == 'bubinadubina5@gmail.com';
    }

    // 4. Reports Collection
    match /reports/{reportId} {
      allow create: if isValidId(incoming().serverId) && 
                       incoming().createdAt == request.time;
      allow get: if true; // Publicly get status if knowing the exact document ID
      allow list, update, delete: if isAdmin();
    }

    // 5. Visits Collection
    match /visits/{visitId} {
      allow create: if true; // Everyone can log a visit (client side)
      allow get, list, update, delete: if isAdmin();
    }

    // 6. Blocked IPs
    match /blocked_ips/{ipId} {
      allow read: if true; // Publicly readable so client can check if they are blocked
      allow write: if isAdmin();
    }

    // 7. Server Suggestions
    function isValidSuggestion(data) {
      return data.displayId is string && data.displayId.size() == 6 &&
             data.name is string && data.name.size() <= 64 &&
             data.protocol is string &&
             data.expiryDate is string &&
             data.country is string &&
             data.city is string &&
             data.config is string && data.config.size() <= 2000 &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    match /server_suggestions/{suggestionId} {
      allow create: if isValidSuggestion(incoming()) && 
                       incoming().status == 'pending' &&
                       incoming().createdAt == request.time;
      allow get: if true; // Anyone knowing the suggestion ID can check its status/details
      allow list: if isAdmin() || 
                    (resource.data.status == 'approved') || 
                    (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // 8. Server Removals
    function isValidRemoval(data) {
      return data.serverId is string &&
             data.suggestionId is string &&
             data.reason is string &&
             data.status in ['pending', 'processed', 'rejected'];
    }

    match /server_removals/{removalId} {
      allow create: if isValidRemoval(incoming()) &&
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      allow get, list, update, delete: if isAdmin();
    }

    // 10. Settings Collection
    function isValidSetting(data) {
      return data.value is string && data.value.size() <= 1000;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSetting(incoming());
    }

    // 11. User Profiles & Username Claims
    function isValidUserProfile(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 15 &&
             data.username.matches('^[a-zA-Z0-9_]+$') &&
             data.displayName is string && data.displayName.size() <= 40 &&
             (data.bio == null || (data.bio is string && data.bio.size() <= 200)) &&
             (data.telegram == null || (data.telegram is string && data.telegram.size() <= 100)) &&
             (data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 500));
    }

    match /users/{userId} {
      allow get: if true;
      allow create: if isSignedIn() && request.auth.uid == userId &&
                      isValidUserProfile(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time &&
                      getAfter(/databases/$(database)/documents/usernames/$(incoming().username)).data.uid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == userId &&
                      isValidUserProfile(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      (incoming().username == existing().username ||
                       getAfter(/databases/$(database)/documents/usernames/$(incoming().username)).data.uid == request.auth.uid);
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() &&
                      incoming().uid == request.auth.uid &&
                      incoming().createdAt == request.time &&
                      username.size() >= 3 && username.size() <= 15 &&
                      username.matches('^[a-zA-Z0-9_]+$') &&
                      username == username.lower();
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    // 9. Test Path (Internal)
    match /test/connection {
      allow read: if true;
    }
  }
}
