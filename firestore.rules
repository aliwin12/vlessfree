rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'bubinadubina5@gmail.com' ||
        request.auth.token.email == 'intelxeonuser@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Servers Collection
    function isValidServer(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.protocol is string &&
             (data.latency == null || data.latency is string) &&
             data.load is number &&
             data.expiryDate is string &&
             data.status in ['online', 'offline'] &&
             data.config is string && data.config.size() <= 2000 &&
             data.country is string && data.country.size() == 2 &&
             (data.city == null || data.city is string) &&
             (data.remark == null || data.remark is string);
    }

    match /servers/{serverId} {
      allow get, list: if true;
      allow create: if isAdmin() && 
                      isValidServer(incoming()) &&
                      incoming().createdAt == request.time;
      allow update: if isAdmin() && 
                      isValidServer(incoming());
      allow delete: if isAdmin();
    }

    // 2. Warnings Collection
    function isValidWarning(data) {
      return data.text is string && data.text.size() <= 1000 &&
             data.type in ['info', 'warning', 'error'] &&
             data.active is bool &&
             data.replaceContent is bool;
    }

    match /warnings/{warningId} {
      allow get, list: if true;
      allow create: if isAdmin() && 
                      isValidWarning(incoming()) && 
                      incoming().createdAt == request.time;
      allow update: if isAdmin() && 
                      isValidWarning(incoming());
      allow delete: if isAdmin();
    }

    // 3. Admin Roles Collection
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isVerified() && request.auth.token.email == 'bubinadubina5@gmail.com';
    }

    // 4. Test Path (Internal)
    match /test/connection {
      allow read: if true;
    }
  }
}
